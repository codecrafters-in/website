# Copy this file to .env and fill in your values
# Never commit .env to version control

# Site URL (used for OG tags, sitemaps)
VITE_SITE_URL=https://codecrafters.ai

# Analytics (optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Contact form endpoint (optional — if using a form backend)
VITE_CONTACT_ENDPOINT=https://api.codecrafters.ai/contact
