# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# Site URL
VITE_SITE_URL=https://codecrafters.in

# ── EmailJS (emailjs.com — free, connects your Gmail/SMTP) ──────────────
# 1. Sign up at emailjs.com
# 2. Add Email Service → connect Gmail → copy Service ID
# 3. Create Email Template for contact form → copy Template ID
# 4. Create Email Template for checklist/lead magnet → copy Template ID
# 5. Account → API Keys → copy Public Key
# 6. Account → Security → restrict to domain: codecrafters.in
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_CONTACT=template_xxxxxxx
VITE_EMAILJS_TEMPLATE_CHECKLIST=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxx

# ── Booking (cal.com — free for individuals) ────────────────────────────
# Sign up at cal.com → create a 30-min event type → copy the URL
VITE_CAL_URL=https://cal.com/yourname/30min

# ── WhatsApp (optional) ─────────────────────────────────────────────────
# Your WhatsApp Business number in international format (no spaces)
VITE_WHATSAPP_NUMBER=+91XXXXXXXXXX

# ── Contact email ────────────────────────────────────────────────────────
VITE_CONTACT_EMAIL=hello@codecrafters.in

# ── Analytics (optional) ─────────────────────────────────────────────────
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
