# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# Site URL
VITE_SITE_URL=https://codecrafters.in

# ── Gmail SMTP (server-side only — never expose these in frontend code) ──
# 1. Use your Gmail address as GMAIL_USER
# 2. GMAIL_APP_PASSWORD: Google Account → Security → 2-Step Verification
#    → App passwords → generate one for "Mail" → paste the 16-char code
# 3. Set these in Vercel dashboard: Settings → Environment Variables
#    These are NOT VITE_ prefixed — they stay server-side only
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
CONTACT_EMAIL=hello@codecrafters.in

# ── Booking (cal.com — free for individuals) ────────────────────────────
# Sign up at cal.com → create a 30-min event type → copy the URL
VITE_CAL_URL=https://cal.com/yourname/30min

# ── WhatsApp (optional) ─────────────────────────────────────────────────
# Your WhatsApp Business number in international format (no spaces)
VITE_WHATSAPP_NUMBER=+91XXXXXXXXXX

# ── Contact email ────────────────────────────────────────────────────────
VITE_CONTACT_EMAIL=hello@codecrafters.in

# ── Analytics (optional) ─────────────────────────────────────────────────
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
